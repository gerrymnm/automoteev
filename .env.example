# ================================================================
# Automoteev environment variables
# Copy to apps/api/.env (backend) and apps/web/.env (frontend)
# ================================================================

# -------- Shared --------
NODE_ENV=development

# =================================================================
# FRONTEND (apps/web) — prefix every var with VITE_ to expose it
# =================================================================
VITE_SUPABASE_URL=https://euouyaarpowxpmbyzxmk.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_qoN70J_RDJKx_X0mOy6vRA_wF1Yip2g
VITE_API_URL=http://localhost:4000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_STRIPE_PRICE_MONTHLY=price_automoteev_pro_monthly
VITE_STRIPE_PRICE_ANNUAL=price_automoteev_pro_annual
VITE_APP_URL=http://localhost:5173

# =================================================================
# BACKEND (apps/api) — never prefix with VITE_, these stay on server
# =================================================================
PORT=4000
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# ---- Supabase ----
SUPABASE_URL=https://euouyaarpowxpmbyzxmk.supabase.co
SUPABASE_ANON_KEY=sb_publishable_qoN70J_RDJKx_X0mOy6vRA_wF1Yip2g
# service_role secret — Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Anthropic (agent reasoning) ----
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Resend (outbound + inbound email) ----
RESEND_API_KEY=re_your_key
RESEND_FROM_DOMAIN=mail.automoteev.com
RESEND_REPLY_TO_DOMAIN=mail.automoteev.com
RESEND_INBOUND_WEBHOOK_SECRET=generate-32-byte-random-string
RESEND_EVENTS_WEBHOOK_SECRET=generate-32-byte-random-string

# ---- Stripe (web subscriptions) ----
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
STRIPE_PRICE_MONTHLY=price_automoteev_pro_monthly
STRIPE_PRICE_ANNUAL=price_automoteev_pro_annual

# ---- Google (Places + Maps for vendor discovery) ----
GOOGLE_MAPS_API_KEY=your-google-maps-key

# ---- EIA (free gas price API) ----
# Register at https://api.eia.gov/register
EIA_API_KEY=your-eia-key

# ---- Agent autonomy settings ----
# Number of provider emails the user must approve before the agent
# auto-sends. Matches the product promise: "first 3 are approvals".
AUTONOMY_APPROVAL_THRESHOLD=3

# ---- Field-level encryption (DL, policy #, phone, address) ----
# Generate with:   openssl rand -base64 32
PII_ENCRYPTION_KEY=replace-with-32-byte-base64-key-before-production

# ---- Legal versions (bumps force re-acceptance) ----
TOS_VERSION=2026-04-24
PRIVACY_VERSION=2026-04-24
AUTONOMY_CONSENT_VERSION=2026-04-24
